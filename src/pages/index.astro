---
// Root redirector. GitHub Pages is static, so language detection happens
// client-side (navigator.language) with an EN fallback. Kept out of the index.
import { liveLocales, defaultLocale } from '../i18n/config';
const live = JSON.stringify(liveLocales);
const fallback = defaultLocale;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, follow" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="MfsJjlHEX5DgdmvRmGW58CDv11iI_cQ8AZBkGcp-P3w" />
  <title>The South of France</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://the-south-of-france.com/${fallback}/`} />
  <meta http-equiv="refresh" content={`0; url=/${fallback}/`} />
  <script is:inline define:vars={{ live, fallback }}>
    (function () {
      try {
        var supported = JSON.parse(live);
        var pref = (navigator.languages || [navigator.language || fallback])
          .map(function (l) { return String(l).slice(0, 2).toLowerCase(); });
        var pick = fallback;
        for (var i = 0; i < pref.length; i++) {
          if (supported.indexOf(pref[i]) !== -1) { pick = pref[i]; break; }
        }
        window.location.replace('/' + pick + '/');
      } catch (e) {
        window.location.replace('/' + fallback + '/');
      }
    })();
  </script>
</head>
<body>
  <p style="font-family: Georgia, serif; padding: 2rem;">
    Redirecting… <a href={`/${fallback}/`}>The South of France</a>
  </p>
</body>
</html>
