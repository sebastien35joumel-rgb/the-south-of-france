---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Article from '../../../components/pages/Article.astro';
import Adresse from '../../../components/pages/Adresse.astro';
import { slugs, liveLocales, nestedUrl, nestedAlternates, type Locale, type SectionKey } from '../../../i18n/config';
import { articles } from '../../../data/article';
import { adresses } from '../../../data/adresse';
import { NESTED } from '../../../data/nested';

// Nested content pages: an article lives under its region, an address
// under its region or under "stays" / "the-table". The entry slug is
// stable across locales; only the parent (section) slug is translated.
// The registry (parent → URL segment) lives in data/nested.ts so the
// Journal index can build a complete, orphan-free list from the same set.
export function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of liveLocales) {
    for (const n of NESTED) {
      const store: any = n.kind === 'article' ? articles[n.entry] : adresses[n.entry];
      if (!store || !store[lang]) continue;
      paths.push({
        params: { lang, section: slugs[n.parent][lang], entry: n.entry },
        props: { kind: n.kind, parent: n.parent, entry: n.entry, locale: lang },
      });
    }
  }
  return paths;
}

const props = Astro.props as any;
const locale = props.locale as Locale;
const kind = props.kind as string;
const parent = props.parent as SectionKey;
const entry = props.entry as string;

const content: any = kind === 'article' ? articles[entry][locale] : adresses[entry][locale];
const canonicalUrl = nestedUrl(locale, parent, entry);
const alternates = nestedAlternates(parent, entry);
---
<Base
  locale={locale}
  section={parent}
  title={content.title}
  description={content.description}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
>
  <Nav locale={locale} section={parent} />
  {kind === 'article' && <Article locale={locale} c={content} />}
  {kind === 'adresse' && <Adresse locale={locale} c={content} />}
  <Footer locale={locale} />
</Base>
